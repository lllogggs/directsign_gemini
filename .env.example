# GEMINI_API_KEY:
# Optional/reserved for future server-side Gemini features. The current public
# launch path does not require it, and it must never be exposed with a VITE_
# prefix if enabled later.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, auth callbacks, and API endpoints.
# Set this explicitly in Vercel production.
APP_URL="https://yeollock.me"
VITE_PUBLIC_SITE_URL="https://yeollock.me"

# PRODUCT_NAME / VITE_PRODUCT_NAME:
# Display name used by server logs, HTML metadata, and client UI.
# Keep them aligned when frontend and API environments are managed separately.
PRODUCT_NAME="yeollock.me"
VITE_PRODUCT_NAME="yeollock.me"

# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY:
# Optional. When both are set, the local API stores contracts in Supabase.
# Keep the service role key server-side only. Do not prefix it with VITE_.
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_CONTRACTS_TABLE="directsign_contracts"
SUPABASE_SCHEMA_VERSION="v2"

# ADMIN_ACCESS_CODE / ADMIN_OPERATOR_NAME / ADMIN_SESSION_SECRET / DIRECTSIGN_TOKEN_ENCRYPTION_SECRET:
# Generate strong values with: npm run secrets:generate
# Required for production operations. Keep server-side only. Do not prefix with VITE_.
# Local development auto-generates missing runtime secrets in ignored data/runtime-secrets.json.
ADMIN_ACCESS_CODE=""
ADMIN_OPERATOR_NAME=""
ADMIN_SESSION_SECRET=""
ADMIN_LOGIN_MAX_FAILURES="5"
ADMIN_LOGIN_WINDOW_SECONDS="900"
ADMIN_LOGIN_LOCK_SECONDS="900"
PUBLIC_AUTH_IP_MAX_ATTEMPTS="40"
PUBLIC_AUTH_EMAIL_MAX_ATTEMPTS="8"
PUBLIC_AUTH_WINDOW_SECONDS="900"
SENSITIVE_ENDPOINT_IP_MAX_ATTEMPTS="60"
SENSITIVE_ENDPOINT_SUBJECT_MAX_ATTEMPTS="20"
SENSITIVE_ENDPOINT_WINDOW_SECONDS="900"
DIRECTSIGN_TOKEN_ENCRYPTION_SECRET=""
CONTENT_SECURITY_POLICY_REPORT_ONLY="false"

# DIRECTSIGN_DEMO_MODE:
# Set to "true" only for demos. Real service mode keeps an empty DB empty.
DIRECTSIGN_DEMO_MODE="false"
DIRECTSIGN_ALLOW_PRODUCTION_DEMO_MODE="false"
DIRECTSIGN_DEFAULT_ADVERTISER_ID="adv_1"
DIRECTSIGN_DEFAULT_INFLUENCER_ID="influencer_guest"
DIRECTSIGN_ALLOW_LOCAL_PRIVATE_FILE_FALLBACK="false"

# SIGNED_PDF_FONT_PATH:
# Optional but recommended. Point to a TTF Korean font so signed contract PDFs
# can embed readable Korean text in server-generated evidence records.
SIGNED_PDF_FONT_PATH=""

# Public legal document operator information. These values are intentionally
# client-visible because privacy/terms pages must disclose the operating entity.
# Use "free_individual" while there is no business registration and the service
# is provided for free. Switch to "registered_business" before paid/business use.
VITE_LEGAL_OPERATING_MODE="free_individual"
VITE_LEGAL_OPERATOR_NAME=""
VITE_LEGAL_REPRESENTATIVE_NAME=""
VITE_LEGAL_BUSINESS_REGISTRATION_NUMBER=""
VITE_LEGAL_MAIL_ORDER_BUSINESS_NUMBER=""
VITE_LEGAL_ADDRESS=""
VITE_LEGAL_CONTACT_EMAIL="support@yeollock.me"
VITE_LEGAL_CONTACT_PHONE=""
